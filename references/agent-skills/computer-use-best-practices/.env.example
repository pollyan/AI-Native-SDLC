ANTHROPIC_API_KEY=sk-ant-...

# Provider: anthropic (default), vertex, or bedrock.
# CU_PROVIDER=anthropic
# For vertex: set GOOGLE_CLOUD_PROJECT and GOOGLE_CLOUD_REGION.
# For bedrock: set AWS_REGION; credentials via the standard AWS chain.

# Point at a TOML file to override any constants.Config field.
# CU_CONFIG=config.toml

# Or override individual fields with CU_<FIELD_NAME>, e.g.:
# CU_ENABLE_ADVISOR_TOOL=true
# CU_IMAGE_PRUNE_STRATEGY=none
# CU_JPEG_QUALITY=80

# Override the API endpoint (e.g. a corporate proxy or LLM gateway).
# ANTHROPIC_BASE_URL=https://...

# Comma-separated list of additional model IDs to accept via --model
# (older or beta models not in the built-in list).
# COMPUTER_USE_EXTRA_MODELS=some-old-model,another-beta-model

# Uncomment if your Playwright browsers are installed somewhere other than the
# default ~/Library/Caches/ms-playwright (e.g. you ran
# `PLAYWRIGHT_BROWSERS_PATH=... playwright install`).
# PLAYWRIGHT_BROWSERS_PATH=/path/to/ms-playwright
